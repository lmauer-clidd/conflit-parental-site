---
interface Props {
  items: { label: string; href?: string }[];
  class?: string;
}
const { items, class: className = '' } = Astro.props;
---
<nav aria-label="Fil d'Ariane" class:list={['text-sm text-muted', className]}>
  <ol class="flex flex-wrap items-center gap-1.5">
    <li>
      <a href="/" class="hover:text-brand-700">Accueil</a>
    </li>
    {
      items.map((item) => (
        <li class="flex items-center gap-1.5">
          <span aria-hidden="true" class="text-line">/</span>
          {item.href ? (
            <a href={item.href} class="hover:text-brand-700">
              {item.label}
            </a>
          ) : (
            <span class="text-body" aria-current="page">
              {item.label}
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
