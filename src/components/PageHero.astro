---
import Breadcrumbs from './Breadcrumbs.astro';

interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  crumbs?: { label: string; href?: string }[];
}
const { eyebrow, title, lede, crumbs } = Astro.props;
---
<section class="relative overflow-hidden bg-sand">
  <!-- voile décoratif doux -->
  <div
    class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-brand-100/60 blur-3xl"
    aria-hidden="true"
  >
  </div>
  <div class="container-page relative py-14 sm:py-20">
    {crumbs && <Breadcrumbs items={crumbs} class="mb-6" />}
    {
      eyebrow && (
        <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-clay-700">{eyebrow}</p>
      )
    }
    <h1 class="max-w-3xl text-4xl leading-tight sm:text-5xl">{title}</h1>
    {lede && <p class="mt-6 max-w-2xl text-lg leading-relaxed text-body sm:text-xl">{lede}</p>}
    <slot />
  </div>
</section>
