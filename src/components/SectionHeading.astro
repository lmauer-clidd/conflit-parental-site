---
interface Props {
  eyebrow?: string;
  title: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, title, align = 'left', class: className = '' } = Astro.props;
const alignment = align === 'center' ? 'text-center mx-auto' : '';
---
<div class:list={['max-w-2xl', alignment, className]}>
  {
    eyebrow && (
      <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-clay-600">{eyebrow}</p>
    )
  }
  <h2 class="text-3xl sm:text-[2.1rem]">{title}</h2>
  <div class:list={['mt-5 text-lg leading-relaxed text-body', align === 'center' ? '' : '']}>
    <slot />
  </div>
</div>
