---
interface Props {
  tone?: 'cream' | 'sand' | 'white' | 'brand';
  class?: string;
  id?: string;
}
const { tone = 'cream', class: className = '', id } = Astro.props;

const tones: Record<string, string> = {
  cream: 'bg-cream',
  sand: 'bg-sand',
  white: 'bg-white',
  brand: 'bg-brand-800 text-brand-50',
};
---
<section id={id} class:list={['py-16 sm:py-20', tones[tone], className]}>
  <div class="container-page">
    <slot />
  </div>
</section>
