---
// Logo officiel « L'enfant au milieu » : deux profils de parents (bleu encre)
// formant un cœur, abritant l'enfant (terracotta) au centre. Fond transparent.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<img
  src="/images/logo.png"
  alt="L'enfant au milieu"
  width="1905"
  height="1841"
  class:list={['object-contain', className]}
/>
