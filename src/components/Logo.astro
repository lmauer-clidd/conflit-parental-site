---
// Marque « L'enfant au milieu » — une arche protectrice abritant un point central
// (l'enfant, au centre, protégé). Sobre, non figuratif, rassurant.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg
  class={className}
  width="40"
  height="40"
  viewBox="0 0 40 40"
  fill="none"
  role="img"
  aria-label="L'enfant au milieu"
  xmlns="http://www.w3.org/2000/svg"
>
  <circle cx="20" cy="20" r="19" fill="var(--color-brand-600)" />
  <!-- arche / abri -->
  <path
    d="M9 25c0-6.6 4.9-12 11-12s11 5.4 11 12"
    stroke="var(--color-brand-100)"
    stroke-width="2.4"
    stroke-linecap="round"
  />
  <path
    d="M13 25c0-3.9 3.1-7 7-7s7 3.1 7 7"
    stroke="var(--color-clay-300)"
    stroke-width="2.2"
    stroke-linecap="round"
  />
  <!-- l'enfant, au centre -->
  <circle cx="20" cy="25.5" r="3" fill="#ffffff" />
</svg>
