---
import { mainNav, site } from '../data/site';
import Logo from './Logo.astro';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-40 border-b border-line/70 bg-cream/85 backdrop-blur-md">
  <div class="container-page flex h-[4.5rem] items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 shrink-0" aria-label={`${site.name} — accueil`}>
      <Logo class="h-9 w-9" />
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="font-display text-[1.05rem] font-medium text-ink">{site.name}</span>
        <span class="text-[0.7rem] uppercase tracking-[0.14em] text-muted">Psychologie · Dossier · Preuves</span>
      </span>
    </a>

    <!-- Navigation bureau -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Navigation principale">
      {
        mainNav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'whitespace-nowrap rounded-lg px-3 py-2 text-[0.95rem] transition-colors',
              isActive(item.href)
                ? 'text-brand-800 font-medium'
                : 'text-body hover:text-brand-700 hover:bg-brand-50',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={site.contact.phoneHref}
        class="hidden xl:inline-flex items-center gap-2 whitespace-nowrap rounded-lg px-3 py-2 text-[0.95rem] text-body hover:text-brand-700"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25c1.1.37 2.3.57 3.5.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.3a1 1 0 0 1 1 1c0 1.2.2 2.4.57 3.5a1 1 0 0 1-.25 1l-2.2 2.3Z"
            fill="currentColor"
          />
        </svg>
        {site.contact.phone}
      </a>
      <a
        href="/contact"
        class="hidden sm:inline-flex items-center rounded-xl bg-brand-600 px-4 py-2.5 text-[0.95rem] font-medium text-white shadow-soft transition-colors hover:bg-brand-700"
      >
        Prendre contact
      </a>

      <!-- Bouton menu mobile -->
      <button
        type="button"
        id="menu-toggle"
        class="lg:hidden inline-flex h-11 w-11 items-center justify-center rounded-xl text-ink hover:bg-brand-50"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
        <svg id="icon-close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Panneau mobile -->
  <nav
    id="mobile-menu"
    class="lg:hidden hidden border-t border-line/70 bg-cream"
    aria-label="Navigation mobile"
  >
    <div class="container-page flex flex-col gap-1 py-4">
      {
        mainNav.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'rounded-lg px-3 py-3 text-base',
              isActive(item.href) ? 'bg-brand-50 text-brand-800 font-medium' : 'text-body hover:bg-brand-50',
            ]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/contact"
        class="mt-2 inline-flex items-center justify-center rounded-xl bg-brand-600 px-4 py-3 font-medium text-white"
      >
        Prendre contact
      </a>
      <a href={site.contact.phoneHref} class="px-3 py-2 text-sm text-muted">
        Ou par téléphone : {site.contact.phone}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  function setMenu(open: boolean) {
    if (!menu || !toggle) return;
    menu.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Fermer le menu' : 'Ouvrir le menu');
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  }

  toggle?.addEventListener('click', () => {
    setMenu(menu?.classList.contains('hidden') ?? true);
  });

  // Fermeture au clic sur un lien du menu
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });

  // Échap : ferme le menu et redonne le focus au bouton
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) {
      setMenu(false);
      toggle?.focus();
    }
  });
</script>
