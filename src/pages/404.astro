---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page introuvable" description="Cette page n’existe pas ou a été déplacée." noindex={true}>
  <section class="bg-sand">
    <div class="container-page flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
      <p class="font-display text-6xl text-brand-300">404</p>
      <h1 class="mt-4 text-3xl sm:text-4xl">Cette page est introuvable</h1>
      <p class="mt-4 max-w-md text-lg text-body">
        Le lien est peut-être ancien ou la page a été déplacée. Revenons à l’essentiel.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href="/">Retour à l’accueil</Button>
        <Button href="/contact" variant="ghost">Prendre contact</Button>
      </div>
    </div>
  </section>
</BaseLayout>
