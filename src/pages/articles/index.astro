---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import { getCollection } from 'astro:content';

const description =
  'Ressources et repères sur les séparations à haut conflit : refus de lien, conflit de loyauté, dossier JAF, expertises. Des articles clairs, pour comprendre et agir avec justesse.';

const articles = (await getCollection('articles', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const fmt = (d: Date) =>
  new Intl.DateTimeFormat('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' }).format(d);
---

<BaseLayout title="Articles & ressources" description={description}>
  <PageHero
    eyebrow="Articles & ressources"
    title="Comprendre, avec des repères clairs"
    lede="Des articles courts et concrets sur les situations que vous traversez peut-être. Pour y voir plus clair, sans jargon."
    crumbs={[{ label: 'Articles' }]}
  />

  <Section tone="cream">
    {
      articles.length === 0 ? (
        <p class="text-body">Les premiers articles arrivent bientôt.</p>
      ) : (
        <div class="grid gap-6 md:grid-cols-2">
          {articles.map((article) => (
            <Card href={`/articles/${article.id}`} class="group flex flex-col">
              <div class="flex flex-wrap items-center gap-2 text-sm text-muted">
                <time datetime={article.data.pubDate.toISOString()}>{fmt(article.data.pubDate)}</time>
              </div>
              <h2 class="mt-3 text-xl text-ink group-hover:text-brand-700">{article.data.title}</h2>
              <p class="mt-3 grow text-body">{article.data.description}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brand-700">
                Lire l’article
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </Card>
          ))}
        </div>
      )
    }
  </Section>

  <ContactCTA />
</BaseLayout>
