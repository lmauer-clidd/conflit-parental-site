---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { landings, getLanding } from '../data/landings';
import { site } from '../data/site';

export function getStaticPaths() {
  return landings.map((l) => ({ params: { slug: l.slug } }));
}

const { slug } = Astro.params;
const landing = getLanding(slug!);
if (!landing) {
  return Astro.redirect('/404');
}

const related = (landing.relatedSlugs ?? [])
  .map((s) => getLanding(s))
  .filter((l): l is NonNullable<typeof l> => Boolean(l));

// JSON-LD : fil d'Ariane + FAQ (si présente)
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: site.url },
    { '@type': 'ListItem', position: 2, name: landing.navLabel, item: `${site.url}/${landing.slug}` },
  ],
};

const faqSchema = landing.faq
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: landing.faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;

const schema = faqSchema ? [breadcrumb, faqSchema] : [breadcrumb];
---

<BaseLayout title={landing.seoTitle} description={landing.metaDescription} schema={schema}>
  <PageHero
    eyebrow={landing.eyebrow}
    title={landing.h1}
    lede={landing.lede}
    crumbs={[{ label: landing.navLabel }]}
  />

  <!-- Contenu -->
  <Section tone="cream">
    <div class="prose-soft">
      {
        landing.sections.map((sec) => (
          <div>
            <h2>{sec.heading}</h2>
            {sec.body.map((p) => (
              <p>{p}</p>
            ))}
            {sec.list && (
              <ul>
                {sec.list.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            )}
          </div>
        ))
      }
    </div>
  </Section>

  <!-- FAQ -->
  {
    landing.faq && (
      <Section tone="sand">
        <div class="max-w-2xl">
          <p class="mb-3 text-sm font-semibold uppercase tracking-[0.14em] text-clay-700">Questions fréquentes</p>
          <h2 class="text-3xl">Vos questions</h2>
        </div>
        <div class="mt-8 max-w-3xl space-y-4">
          {landing.faq.map((f) => (
            <details class="group rounded-2xl border border-line bg-white p-5 shadow-soft">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium text-ink">
                {f.q}
                <svg class="h-5 w-5 shrink-0 text-brand-500 transition-transform group-open:rotate-45" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </summary>
              <p class="mt-3 text-body">{f.a}</p>
            </details>
          ))}
        </div>
      </Section>
    )
  }

  <!-- Pages liées -->
  {
    related.length > 0 && (
      <Section tone="cream">
        <h2 class="text-2xl">À lire aussi</h2>
        <div class="mt-6 grid gap-5 sm:grid-cols-2">
          {related.map((r) => (
            <Card href={`/${r.slug}`} class="group">
              <h3 class="text-lg text-ink group-hover:text-brand-700">{r.navLabel}</h3>
              <p class="mt-2 text-[0.97rem] text-body">{r.teaser}</p>
            </Card>
          ))}
        </div>
      </Section>
    )
  }

  <ContactCTA />
</BaseLayout>
